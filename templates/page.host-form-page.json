      "settings": {
        "custom_liquid": "{{ 'section-contact-form.css' | asset_url | stylesheet_tag }}\n\n{%- style -%}\n  .section-{{ section.id }}-padding {\n    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;\n    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;\n  }\n\n  @media screen and (min-width: 750px) {\n    .section-{{ section.id }}-padding {\n      padding-top: {{ section.settings.padding_top }}px;\n      padding-bottom: {{ section.settings.padding_bottom }}px;\n    }\n  }\n\n  .section-{{ section.id }}-padding .button {\n    border: none !important;\n    border-color: transparent !important;\n    outline: none !important;\n    box-shadow: none !important;\n    border-radius: 12px;\n  }\n\n  .workshop-list {\n    display: flex;\n    flex-direction: column;\n    gap: 1.6rem;\n    margin-bottom: 1.6rem;\n  }\n\n  .workshop-row {\n  display: grid;\n  grid-template-columns: 1.6fr 1fr 1fr;\n  gap: 1.2rem;\n  align-items: stretch;\n}\n\n.workshop-row .field__input {\n  box-sizing: border-box;\n}\n\n.workshop-row input.field__input,\n.workshop-row select.field__input {\n  min-height: calc(4.5rem + (var(--inputs-border-width, 1px) * 2));\n  height: calc(4.5rem + (var(--inputs-border-width, 1px) * 2));\n}\n\n.workshop-row select.field__input {\n  padding: 0 1.5rem;\n  padding-right: 3.6rem;\n  line-height: normal;\n  display: block;\n  appearance: none;\n  -webkit-appearance: none;\n  -moz-appearance: none;\n}\n\n  .workshop-add-button {\n    background: transparent;\n    border: 1px solid currentColor;\n    border-radius: 12px;\n    padding: 1rem 1.4rem;\n    cursor: pointer;\n    font: inherit;\n  }\n\n  .workshop-hidden-field {\n    display: none !important;\n  }\n\n  @media screen and (max-width: 749px) {\n    .workshop-row {\n      grid-template-columns: 1fr;\n    }\n  }\n{%- endstyle -%}\n\n<div class=\"color-{{ section.settings.color_scheme }} gradient\">\n  <div class=\"contact page-width page-width--narrow section-{{ section.id }}-padding\">\n    {%- if section.settings.heading != blank -%}\n      <h2 class=\"title title-wrapper--no-top-margin inline-richtext {{ section.settings.heading_size }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}\">\n        {{ section.settings.heading }}\n      </h2>\n    {%- else -%}\n      <h2 class=\"visually-hidden\">{{ 'templates.contact.form.title' | t }}</h2>\n    {%- endif -%}\n\n    {%- liquid\n      assign contact_form_class = 'isolate'\n      if settings.animations_reveal_on_scroll\n        assign contact_form_class = 'isolate scroll-trigger animate--slide-in'\n      endif\n    -%}\n\n    {%- form 'contact', id: 'ContactForm', class: contact_form_class -%}\n      {{ form.errors | default_errors }}\n\n      {%- if form.posted_successfully? -%}\n        <h2 class=\"form-status form-status-list form__message\" tabindex=\"-1\" autofocus>\n          {{- 'icon-success.svg' | inline_asset_content -}}\n          Messaggio inviato con successo.\n        </h2>\n      {%- elsif form.errors -%}\n        <div class=\"form__message\">\n          <h2 class=\"form-status caption-large text-body\" role=\"alert\" tabindex=\"-1\" autofocus>\n            {{- 'icon-error.svg' | inline_asset_content -}}\n            Si è verificato un errore. Controlla i campi richiesti.\n          </h2>\n        </div>\n        <ul class=\"form-status-list caption-large\" role=\"list\">\n          {%- if form.errors contains 'email' -%}\n            <li>\n              <a href=\"#ContactForm-email\" class=\"link\">\n                Email {{ form.errors.messages.email }}\n              </a>\n            </li>\n          {%- endif -%}\n        </ul>\n      {%- endif -%}\n\n      <div class=\"contact__fields\">\n        <div class=\"field\">\n          <input\n            class=\"field__input\"\n            autocomplete=\"name\"\n            type=\"text\"\n            id=\"ContactForm-fullname\"\n            name=\"contact[Nome e cognome]\"\n            value=\"{% if form.fullname %}{{ form.fullname }}{% elsif customer %}{{ customer.name }}{% endif %}\"\n            placeholder=\"Nome e cognome\"\n            required\n          >\n          <label class=\"field__label\" for=\"ContactForm-fullname\">Nome e cognome</label>\n        </div>\n\n        <div class=\"field\">\n          <input\n            class=\"field__input\"\n            type=\"text\"\n            id=\"ContactForm-company\"\n            name=\"contact[Nome azienda]\"\n            value=\"{{ form.company }}\"\n            placeholder=\"Nome azienda\"\n          >\n          <label class=\"field__label\" for=\"ContactForm-company\">Nome azienda</label>\n        </div>\n      </div>\n\n      <div class=\"contact__fields\">\n        <div class=\"field\">\n          <input\n            class=\"field__input\"\n            type=\"text\"\n            id=\"ContactForm-cap\"\n            name=\"contact[CAP]\"\n            value=\"{{ form.cap }}\"\n            placeholder=\"CAP\"\n            inputmode=\"numeric\"\n          >\n          <label class=\"field__label\" for=\"ContactForm-cap\">CAP</label>\n        </div>\n\n        <div class=\"field field--with-error\">\n          <input\n            autocomplete=\"email\"\n            type=\"email\"\n            id=\"ContactForm-email\"\n            class=\"field__input\"\n            name=\"contact[email]\"\n            spellcheck=\"false\"\n            autocapitalize=\"off\"\n            value=\"{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}\"\n            aria-required=\"true\"\n            required\n            {% if form.errors contains 'email' %}\n              aria-invalid=\"true\"\n              aria-describedby=\"ContactForm-email-error\"\n            {% endif %}\n            placeholder=\"Mail\"\n          >\n          <label class=\"field__label\" for=\"ContactForm-email\">\n            Mail <span aria-hidden=\"true\">*</span>\n          </label>\n\n          {%- if form.errors contains 'email' -%}\n            <small class=\"contact__field-error\" id=\"ContactForm-email-error\">\n              <span class=\"visually-hidden\">Errore</span>\n              <span class=\"form__message\">\n                <span class=\"svg-wrapper\">\n                  {{- 'icon-error.svg' | inline_asset_content -}}\n                </span>\n                Email {{ form.errors.messages.email }}\n              </span>\n            </small>\n          {%- endif -%}\n        </div>\n      </div>\n\n      <div class=\"contact__fields\">\n        <div class=\"field\">\n          <input\n            type=\"tel\"\n            id=\"ContactForm-phone\"\n            class=\"field__input\"\n            autocomplete=\"tel\"\n            name=\"contact[Telefono]\"\n            pattern=\"[0-9\\-\\+\\s]*\"\n            value=\"{% if form.phone %}{{ form.phone }}{% elsif customer %}{{ customer.phone }}{% endif %}\"\n            placeholder=\"Telefono\"\n          >\n          <label class=\"field__label\" for=\"ContactForm-phone\">Telefono</label>\n        </div>\n\n        <div class=\"field\">\n          <input\n            type=\"text\"\n            id=\"ContactForm-address-instagram\"\n            class=\"field__input\"\n            name=\"contact[Indirizzo o Instagram]\"\n            value=\"{{ form.website }}\"\n            placeholder=\"Indirizzo o Instagram\"\n            required\n          >\n          <label class=\"field__label\" for=\"ContactForm-address-instagram\">\n            Indirizzo o Instagram <span aria-hidden=\"true\">*</span>\n          </label>\n        </div>\n      </div>\n\n      <div style=\"margin-top: 2.5rem; margin-bottom: 1rem;\">\n        <p style=\"margin: 0; font-weight: 600;\">Workshop proposti</p>\n      </div>\n\n      <div id=\"WorkshopList\" class=\"workshop-list\">\n        <div class=\"workshop-row\" data-workshop-index=\"1\">\n          <div class=\"field\">\n            <input\n              type=\"text\"\n              id=\"ContactForm-workshop-name-1\"\n              class=\"field__input workshop-name\"\n              placeholder=\"Nome workshop\"\n            >\n            <label class=\"field__label\" for=\"ContactForm-workshop-name-1\">Nome workshop</label>\n          </div>\n\n          <div class=\"field\">\n            <select\n              id=\"ContactForm-workshop-day-1\"\n              class=\"field__input workshop-day\"\n            >\n              <option value=\"\">Giorno</option>\n              <option value=\"Lunedì\">Lunedì</option>\n              <option value=\"Martedì\">Martedì</option>\n              <option value=\"Mercoledì\">Mercoledì</option>\n              <option value=\"Giovedì\">Giovedì</option>\n              <option value=\"Venerdì\">Venerdì</option>\n              <option value=\"Sabato\">Sabato</option>\n              <option value=\"Domenica\">Domenica</option>\n            </select>\n          </div>\n\n          <div class=\"field\">\n            <select\n              id=\"ContactForm-workshop-time-1\"\n              class=\"field__input workshop-time\"\n            >\n              <option value=\"\">Orario</option>\n              <option value=\"Mattina\">Mattina</option>\n              <option value=\"Pomeriggio\">Pomeriggio</option>\n              <option value=\"Sera\">Sera</option>\n            </select>\n          </div>\n        </div>\n      </div>\n\n      <div style=\"margin-bottom: 2rem;\">\n        <button type=\"button\" id=\"AddWorkshopButton\" class=\"workshop-add-button\">\n          + Aggiungi workshop\n        </button>\n      </div>\n\n      <div class=\"field\">\n        <textarea\n          rows=\"4\"\n          id=\"ContactForm-workshop-notes-visible\"\n          class=\"text-area field__input\"\n          placeholder=\"Prezzi, dettagli aggiuntivi, richieste particolari...\"\n        ></textarea>\n        <label class=\"form__label field__label\" for=\"ContactForm-workshop-notes-visible\">\n          Note aggiuntive sui workshop\n        </label>\n      </div>\n\n      <textarea\n        id=\"ContactForm-body-hidden\"\n        name=\"contact[body]\"\n        class=\"workshop-hidden-field\"\n        aria-hidden=\"true\"\n      >{{ form.body }}</textarea>\n\n      <div class=\"contact__button\">\n        <button type=\"submit\" class=\"button\">\n          Invia\n        </button>\n      </div>\n    {%- endform -%}\n  </div>\n</div>\n\n<script>\n  document.addEventListener('DOMContentLoaded', function () {\n    var form = document.getElementById('ContactForm');\n    var workshopList = document.getElementById('WorkshopList');\n    var addWorkshopButton = document.getElementById('AddWorkshopButton');\n    var bodyHiddenField = document.getElementById('ContactForm-body-hidden');\n    var notesVisibleField = document.getElementById('ContactForm-workshop-notes-visible');\n\n    if (!form || !workshopList || !addWorkshopButton || !bodyHiddenField) return;\n\n    var workshopCount = workshopList.querySelectorAll('.workshop-row').length;\n\n    addWorkshopButton.addEventListener('click', function () {\n      workshopCount += 1;\n\n      var workshopRow = document.createElement('div');\n      workshopRow.className = 'workshop-row';\n      workshopRow.setAttribute('data-workshop-index', workshopCount);\n\n      workshopRow.innerHTML = `\n        <div class=\"field\">\n          <input\n            type=\"text\"\n            id=\"ContactForm-workshop-name-${workshopCount}\"\n            class=\"field__input workshop-name\"\n            placeholder=\"Nome workshop\"\n          >\n          <label class=\"field__label\" for=\"ContactForm-workshop-name-${workshopCount}\">Nome workshop</label>\n        </div>\n\n        <div class=\"field\">\n          <select\n            id=\"ContactForm-workshop-day-${workshopCount}\"\n            class=\"field__input workshop-day\"\n          >\n            <option value=\"\">Giorno</option>\n            <option value=\"Lunedì\">Lunedì</option>\n            <option value=\"Martedì\">Martedì</option>\n            <option value=\"Mercoledì\">Mercoledì</option>\n            <option value=\"Giovedì\">Giovedì</option>\n            <option value=\"Venerdì\">Venerdì</option>\n            <option value=\"Sabato\">Sabato</option>\n            <option value=\"Domenica\">Domenica</option>\n          </select>\n        </div>\n\n        <div class=\"field\">\n          <select\n            id=\"ContactForm-workshop-time-${workshopCount}\"\n            class=\"field__input workshop-time\"\n          >\n            <option value=\"\">Orario</option>\n            <option value=\"Mattina\">Mattina</option>\n            <option value=\"Pomeriggio\">Pomeriggio</option>\n            <option value=\"Sera\">Sera</option>\n          </select>\n        </div>\n      `;\n\n      workshopList.appendChild(workshopRow);\n    });\n\n    form.addEventListener('submit', function () {\n      var rows = workshopList.querySelectorAll('.workshop-row');\n      var parts = [];\n\n      rows.forEach(function (row, index) {\n        var nameField = row.querySelector('.workshop-name');\n        var dayField = row.querySelector('.workshop-day');\n        var timeField = row.querySelector('.workshop-time');\n\n        var name = nameField ? nameField.value.trim() : '';\n        var day = dayField ? dayField.value.trim() : '';\n        var time = timeField ? timeField.value.trim() : '';\n\n        if (name || day || time) {\n          parts.push('Workshop ' + (index + 1));\n          parts.push('Nome: ' + (name || '-'));\n          parts.push('Giorno: ' + (day || '-'));\n          parts.push('Orario: ' + (time || '-'));\n          parts.push('');\n        }\n      });\n\n      if (notesVisibleField && notesVisibleField.value.trim() !== '') {\n        parts.push('Note aggiuntive');\n        parts.push(notesVisibleField.value.trim());\n      }\n\n      bodyHiddenField.value = parts.join('\\n').trim();\n    });\n  });\n</script>",
