abel\" for=\"ContactForm-email\"> Mail <span aria-hidden=\"true\">*</span> </label> {%- if\n                form.errors contains 'email' -%} <small class=\"contact__field-error\" id=\"ContactForm-email-error\"> <span\n                        class=\"visually-hidden\">Errore</span> <span class=\"form__message\"> <span class=\"svg-wrapper\">\n                            {{- 'icon-error.svg' | inline_asset_content -}} </span> Email {{ form.errors.messages.email\n                        }} </span> </small> {%- endif -%} </div>\n        </div>\n        <div class=\"contact__fields\">\n            <div class=\"field\"> <input type=\"tel\" id=\"ContactForm-phone\" class=\"field__input\" autocomplete=\"tel\"\n                    name=\"contact[Telefono]\" pattern=\"[0-9\\-\\+\\s]*\"\n                    value=\"{% if form.phone %}{{ form.phone }}{% elsif customer %}{{ customer.phone }}{% endif %}\"\n                    placeholder=\"Telefono\"> <label class=\"field__label\" for=\"ContactForm-phone\">Telefono</label> </div>\n            <div class=\"field\"> <input type=\"text\" id=\"ContactForm-website\" class=\"field__input\"\n                    name=\"contact[Sito web]\" value=\"{{ form.website }}\" placeholder=\"Website\"> <label\n                    class=\"field__label\" for=\"ContactForm-website\">Website</label> </div>\n        </div>\n        <div class=\"field\"> <textarea rows=\"6\" id=\"ContactForm-workshop\" class=\"text-area field__input\"\n                name=\"contact[Workshop offerti, prezzo esperienze, giorni e orari]\"\n                placeholder=\"Workshop offerti + prezzo esperienze + giorni e orari (opzionale)\">{{ form.body }}</textarea>\n            <label class=\"form__label field__label\" for=\"ContactForm-workshop\"> Raccontaci dei workshop che offri,\n                prezzi, giorni e orari :) </label> </div>\n        <div class=\"contact__button\"> <button type=\"submit\" class=\"button\"> Invia </button> </div> {%- endform -%}\n    </div>\n</d