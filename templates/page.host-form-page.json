      "settings": {
        "custom_liquid": "{{ 'section-contact-form.css' | asset_url | stylesheet_tag }}\n\n{%- style -%}\n  .section-{{ section.id }}-padding {\n    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;\n    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;\n  }\n\n  @media screen and (min-width: 750px) {\n    .section-{{ section.id }}-padding {\n      padding-top: {{ section.settings.padding_top }}px;\n      padding-bottom: {{ section.settings.padding_bottom }}px;\n    }\n  }\n{%- endstyle -%}\n\n<div class=\"color-{{ section.settings.color_scheme }} gradient\">\n  <div class=\"contact page-width section-{{ section.id }}-padding\">\n    <div class=\"contact-form-wrapper\">\n      {%- if section.settings.heading != blank -%}\n        <h2 class=\"contact-form-title title title-wrapper--no-top-margin inline-richtext {{ section.settings.heading_size }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}\">\n          {{ section.settings.heading }}\n        </h2>\n      {%- else -%}\n        <h2 class=\"visually-hidden\">{{ 'templates.contact.form.title' | t }}</h2>\n      {%- endif -%}\n\n      <p class=\"contact-form-subtitle\">\n        Compila il form con i dettagli della tua attività. Ti ricontatteremo al più presto.\n      </p>\n\n      {%- liquid\n        assign contact_form_class = 'custom-contact-form isolate'\n        if settings.animations_reveal_on_scroll\n          assign contact_form_class = 'custom-contact-form isolate scroll-trigger animate--slide-in'\n        endif\n      -%}\n\n      {%- form 'contact', id: 'ContactForm', class: contact_form_class -%}\n        {%- if form.posted_successfully? -%}\n          <div class=\"form-message form-message--success\" tabindex=\"-1\" autofocus>\n            <span class=\"form-message__icon\">\n              {{- 'icon-success.svg' | inline_asset_content -}}\n            </span>\n            <span>Messaggio inviato con successo.</span>\n          </div>\n        {%- elsif form.errors -%}\n          <div class=\"form-message form-message--error\" role=\"alert\" tabindex=\"-1\" autofocus>\n            <span class=\"form-message__icon\">\n              {{- 'icon-error.svg' | inline_asset_content -}}\n            </span>\n            <span>Si è verificato un errore. Controlla i campi richiesti.</span>\n          </div>\n\n          <ul class=\"form-status-list caption-large\" role=\"list\">\n            {%- if form.errors contains 'email' -%}\n              <li>\n                <a href=\"#ContactForm-email\" class=\"link\">\n                  Email {{ form.errors.messages.email }}\n                </a>\n              </li>\n            {%- endif -%}\n          </ul>\n        {%- endif -%}\n\n        <div class=\"contact-form-grid\">\n          <div class=\"field\">\n            <label class=\"field__label field__label--static\" for=\"ContactForm-fullname\">\n              Nome e cognome <span aria-hidden=\"true\">*</span>\n            </label>\n            <input\n              class=\"field__input\"\n              autocomplete=\"name\"\n              type=\"text\"\n              id=\"ContactForm-fullname\"\n              name=\"contact[Nome e cognome]\"\n              value=\"{% if customer %}{{ customer.name }}{% endif %}\"\n              placeholder=\"Es. Mario Rossi\"\n              required\n            >\n          </div>\n\n          <div class=\"field\">\n            <label class=\"field__label field__label--static\" for=\"ContactForm-company\">\n              Nome azienda\n            </label>\n            <input\n              class=\"field__input\"\n              type=\"text\"\n              id=\"ContactForm-company\"\n              name=\"contact[Nome azienda]\"\n              placeholder=\"Es. Studio Creativo Milano\"\n            >\n          </div>\n\n          <div class=\"field\">\n            <label class=\"field__label field__label--static\" for=\"ContactForm-cap\">\n              CAP\n            </label>\n            <input\n              class=\"field__input\"\n              type=\"text\"\n              id=\"ContactForm-cap\"\n              name=\"contact[CAP]\"\n              placeholder=\"Es. 20121\"\n              inputmode=\"numeric\"\n            >\n          </div>\n\n          <div class=\"field field--with-error\">\n            <label class=\"field__label field__label--static\" for=\"ContactForm-email\">\n              Mail <span aria-hidden=\"true\">*</span>\n            </label>\n            <input\n              autocomplete=\"email\"\n              type=\"email\"\n              id=\"ContactForm-email\"\n              class=\"field__input\"\n              name=\"contact[email]\"\n              spellcheck=\"false\"\n              autocapitalize=\"off\"\n              value=\"{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}\"\n              aria-required=\"true\"\n              required\n              {% if form.errors contains 'email' %}\n                aria-invalid=\"true\"\n                aria-describedby=\"ContactForm-email-error\"\n              {% endif %}\n              placeholder=\"Es. nome@azienda.it\"\n            >\n\n            {%- if form.errors contains 'email' -%}\n              <small class=\"contact__field-error\" id=\"ContactForm-email-error\">\n                <span class=\"visually-hidden\">Errore</span>\n                <span class=\"form__message\">\n                  <span class=\"svg-wrapper\">\n                    {{- 'icon-error.svg' | inline_asset_content -}}\n                  </span>\n                  Email {{ form.errors.messages.email }}\n                </span>\n              </small>\n            {%- endif -%}\n          </div>\n\n          <div class=\"field\">\n            <label class=\"field__label field__label--static\" for=\"ContactForm-phone\">\n              Telefono\n            </label>\n            <input\n              type=\"tel\"\n              id=\"ContactForm-phone\"\n              class=\"field__input\"\n              autocomplete=\"tel\"\n              name=\"contact[Telefono]\"\n              pattern=\"[0-9\\-\\+\\s]*\"\n              value=\"{% if customer %}{{ customer.phone }}{% endif %}\"\n              placeholder=\"Es. +39 333 1234567\"\n            >\n          </div>\n\n          <div class=\"field\">\n            <label class=\"field__label field__label--static\" for=\"ContactForm-website\">\n              Website\n            </label>\n            <input\n              type=\"text\"\n              id=\"ContactForm-website\"\n              class=\"field__input\"\n              name=\"contact[Sito web]\"\n              placeholder=\"Es. www.tuosito.it\"\n            >\n          </div>\n\n          <div class=\"field field--full\">\n            <label class=\"field__label field__label--static\" for=\"ContactForm-workshop\">\n              Workshop offerti + prezzo esperienze + giorni e orari\n              <span class=\"field__optional\">(opzionale)</span>\n            </label>\n            <textarea\n              rows=\"7\"\n              id=\"ContactForm-workshop\"\n              class=\"text-area field__input\"\n              name=\"contact[Workshop offerti, prezzo esperienze, giorni e orari]\"\n              placeholder=\"Descrivi brevemente i workshop che offrite, i prezzi indicativi e i giorni/orari disponibili.\"\n            >{{ form.body }}</textarea>\n            <p class=\"field__help-text\">\n              Esempio: ceramica, pittura, cucina, degustazioni, weekend, fascia serale, ecc.\n            </p>\n          </div>\n        </div>\n\n        <div class=\"contact__button\">\n          <button type=\"submit\" class=\"buttonq\">\n            Invia richiesta\n          </button>\n        </div>\n      {%- endform -%}\n    </div>\n  </div>\n</div>",
