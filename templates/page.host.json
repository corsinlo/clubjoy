.host-steps__text {\n    margin: 24px 0 0;\n    font-size: var(--title-size);\n    font-weight: 700;\n    line-height: 1.2;\n    color: var(--text-color);\n  }\n\n  .host-steps-cta {\n    display: flex;\n    justify-content: center;\n    margin-top: 28px;\n  }\n\n  .host-steps-cta__button {\n    display: inline-flex;\n    align-items: center;\n    justify-content: center;\n    background: #0b3bb3;\n    color: #fff;\n    text-decoration: none;\n    border-radius: 999px;\n    padding: 14px 28px;\n    font-size: 16px;\n    font-weight: 700;\n    letter-spacing: 0.02em;\n    line-height: 1;\n    transition: opacity 0.2s ease;\n  }\n\n  .host-steps-cta__button:hover {\n    opacity: 0.9;\n  }\n\n  @media screen and (max-width: 749px) {\n    .host-steps {\n      grid-template-columns: 1fr;\n      row-gap: 40px;\n      padding: 20px 20px 10px;\n    }\n\n    .host-steps::before {\n      display: none;\n    }\n\n    .host-steps__icon {\n      width: 80px;\n      height: 80px;\n      font-size: 54px;\n    }\n\n    .host-steps__number {\n      margin-top: 10px;\n      font-size: 28px;\n    }\n\n    .host-steps__text {\n      margin-top: 14px;\n      font-size: 24px;\n    }\n\n    .host-steps-cta {\n      margin-top: 20px;\n    }\n\n    .host-steps-cta__button {\n      width: 100%;\n      max-width: 320px;\n      padding: 16px 24px;\n    }\n  }\n</style>",
