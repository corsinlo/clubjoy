{% doc %}
  @prompt
    genera un multirow con immagini piu piccole pero
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-multirow-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 0;
  }

  .ai-multirow-container-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.row_spacing }}px;
  }

  .ai-multirow-row-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: {{ block.settings.content_gap }}px;
  }

  .ai-multirow-row-{{ ai_gen_id }}.reverse {
    flex-direction: row-reverse;
  }

  .ai-multirow-image-wrapper-{{ ai_gen_id }} {
    flex: 0 0 {{ block.settings.image_width }}%;
    max-width: {{ block.settings.image_width }}%;
  }

  .ai-multirow-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    border-radius: {{ block.settings.image_border_radius }}px;
    object-fit: cover;
  }

  .ai-multirow-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 4 / 3;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: {{ block.settings.image_border_radius }}px;
    position: relative;
  }

  .ai-multirow-image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-multirow-content-{{ ai_gen_id }} {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .ai-multirow-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0;
    line-height: 1.2;
  }

  .ai-multirow-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    color: {{ block.settings.text_color }};
    line-height: 1.6;
  }

  .ai-multirow-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 12px 24px;
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: 16px;
    transition: background-color 0.3s ease;
    align-self: flex-start;
  }

  .ai-multirow-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-multirow-row-{{ ai_gen_id }},
    .ai-multirow-row-{{ ai_gen_id }}.reverse {
      flex-direction: column;
    }

    .ai-multirow-image-wrapper-{{ ai_gen_id }} {
      flex: 0 0 100%;
      max-width: 100%;
    }

    .ai-multirow-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }

    .ai-multirow-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<ai-multirow-{{ ai_gen_id }} class="ai-multirow-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-multirow-container-{{ ai_gen_id }}">
    {% for i in (1..3) %}
      {% liquid
        assign row_enabled_key = 'row_' | append: i | append: '_enabled'
        assign row_image_key = 'row_' | append: i | append: '_image'
        assign row_heading_key = 'row_' | append: i | append: '_heading'
        assign row_text_key = 'row_' | append: i | append: '_text'
        assign row_button_text_key = 'row_' | append: i | append: '_button_text'
        assign row_button_link_key = 'row_' | append: i | append: '_button_link'
        assign row_layout_key = 'row_' | append: i | append: '_layout'

        assign row_enabled = block.settings[row_enabled_key]
        assign row_image = block.settings[row_image_key]
        assign row_heading = block.settings[row_heading_key]
        assign row_text = block.settings[row_text_key]
        assign row_button_text = block.settings[row_button_text_key]
        assign row_button_link = block.settings[row_button_link_key]
        assign row_layout = block.settings[row_layout_key]
      %}

      {% if row_enabled %}
        <div class="ai-multirow-row-{{ ai_gen_id }} {% if row_layout == 'image_right' %}reverse{% endif %}">
          <div class="ai-multirow-image-wrapper-{{ ai_gen_id }}">
            {% if row_image %}
              <img
                src="{{ row_image | image_url: width: 800 }}"
                alt="{{ row_image.alt | escape }}"
                loading="lazy"
                width="{{ row_image.width }}"
                height="{{ row_image.height }}"
                class="ai-multirow-image-{{ ai_gen_id }}"
              >
            {% else %}
              <div class="ai-multirow-image-placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>

          <div class="ai-multirow-content-{{ ai_gen_id }}">
            {% if row_heading != blank %}
              <h3 class="ai-multirow-heading-{{ ai_gen_id }}">{{ row_heading }}</h3>
            {% endif %}

            {% if row_text != blank %}
              <div class="ai-multirow-text-{{ ai_gen_id }}">{{ row_text }}</div>
            {% endif %}

            {% if row_button_text != blank and row_button_link != blank %}
              <a href="{{ row_button_link }}" class="ai-multirow-button-{{ ai_gen_id }}">
                {{ row_button_text }}
              </a>
            {% endif %}
          </div>
        </div>
      {% endif %}
    {% endfor %}
  </div>
</ai-multirow-{{ ai_gen_id }}>

<script>
  (function() {
    class AiMultirow{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('ai-multirow-{{ ai_gen_id }}', AiMultirow{{ ai_gen_id }});
  })();
</script>

